PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gradia_klasso

# JWT Secrets
JWT_SECRET=super_secret_jwt_sign_key_change_in_production
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_change_in_production

# Redis for BullMQ jobs
REDIS_URL=redis://localhost:6379

# Hubtel Payment Gateway API (Ghana MoMo, Cards)
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_MERCHANT_ACCOUNT=your_hubtel_merchant_account_number

# Africa's Talking API (SMS alerts)
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=sandbox

# WhatsApp Business API (Optional/Future integrations)
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER_NAME=school-documents
